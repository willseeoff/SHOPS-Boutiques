/* =====================================================================
   CREPE N' WAFFLE — Design system & styles
   ===================================================================== */

:root{
  /* Couleurs */
  --bg:        #161311;
  --bg-2:      #1d1815;
  --bg-3:      #241d18;
  --choco:     #3a2318;
  --choco-2:   #5c3a22;
  --gold:      #e7b15a;
  --gold-soft: #f2d6a0;
  --cream:     #fbf7f0;
  --accent:    #e8465b;
  --accent-2:  #c6335a;
  --muted:     rgba(251,247,240,.62);
  --line:      rgba(251,247,240,.12);

  /* Type */
  --serif: "Cormorant Garamond", Georgia, serif;
  --sans:  "Manrope", system-ui, -apple-system, sans-serif;

  /* Espace / rythme */
  --pad: clamp(1.25rem, 5vw, 6rem);
  --radius: 18px;
  --ease: cubic-bezier(.16,1,.3,1);
  --dur: .7s;
}

*{ margin:0; padding:0; box-sizing:border-box; }
html{ scroll-behavior:smooth; -webkit-text-size-adjust:100%; }
body{
  font-family:var(--sans);
  background:var(--bg);
  color:var(--cream);
  line-height:1.6;
  overflow-x:hidden;
  -webkit-font-smoothing:antialiased;
}
img{ max-width:100%; display:block; }
a{ color:inherit; text-decoration:none; }
::selection{ background:var(--accent); color:#fff; }

/* ---------- Loader ---------- */
.loader{
  position:fixed; inset:0; z-index:9999;
  display:flex; flex-direction:column; align-items:center; justify-content:center; gap:1.2rem;
  background:var(--bg); transition:opacity .6s var(--ease), visibility .6s;
}
.loader.done{ opacity:0; visibility:hidden; }
.loader__mark{ font-size:3rem; animation:floaty 2.4s ease-in-out infinite; }
.loader__bar{ width:min(240px,50vw); height:2px; background:var(--line); border-radius:2px; overflow:hidden; }
.loader__bar span{ display:block; height:100%; width:0; background:linear-gradient(90deg,var(--gold),var(--accent)); }
.loader__pct{ font-size:.8rem; letter-spacing:.25em; color:var(--muted); }
@keyframes floaty{ 50%{ transform:translateY(-10px) rotate(-4deg); } }

/* ---------- Curseur ---------- */
.cursor{
  position:fixed; top:0; left:0; width:34px; height:34px; margin:-17px 0 0 -17px;
  border:1px solid var(--gold); border-radius:50%; z-index:9000; pointer-events:none;
  transition:transform .18s var(--ease), background .3s, border-color .3s, opacity .3s;
  mix-blend-mode:difference; opacity:0;
}
.cursor.is-hover{ transform:scale(1.9); background:var(--gold); border-color:var(--gold); }
@media (pointer:coarse){ .cursor{ display:none; } }

/* ---------- Nav ---------- */
.nav{
  position:fixed; top:0; left:0; right:0; z-index:200;
  display:flex; align-items:center; justify-content:space-between;
  padding:1.1rem var(--pad);
  transition:background .4s var(--ease), padding .4s var(--ease), box-shadow .4s;
}
.nav.solid{
  background:rgba(22,19,17,.72); backdrop-filter:blur(14px);
  padding:.7rem var(--pad); box-shadow:0 1px 0 var(--line);
}
.nav__logo{ font-family:var(--serif); font-size:1.35rem; font-weight:700; letter-spacing:.02em; }
.nav__logo span{ color:var(--gold); }
.nav__links{ display:flex; gap:2rem; margin-left:auto; margin-right:2rem; }
.nav__links a{ font-size:.82rem; font-weight:600; letter-spacing:.08em; text-transform:uppercase; color:var(--muted); position:relative; }
.nav__links a::after{ content:""; position:absolute; left:0; bottom:-6px; width:0; height:1px; background:var(--gold); transition:width .35s var(--ease); }
.nav__links a:hover{ color:var(--cream); }
.nav__links a:hover::after{ width:100%; }
.nav__burger{ display:none; background:none; border:0; flex-direction:column; gap:6px; cursor:pointer; padding:6px; }
.nav__burger span{ width:26px; height:2px; background:var(--cream); transition:.35s var(--ease); }
.nav.open .nav__burger span:nth-child(1){ transform:translateY(4px) rotate(45deg); }
.nav.open .nav__burger span:nth-child(2){ transform:translateY(-4px) rotate(-45deg); }

/* ---------- Boutons ---------- */
.btn{
  display:inline-flex; align-items:center; justify-content:center; gap:.5rem;
  font-family:var(--sans); font-weight:600; font-size:.9rem; letter-spacing:.02em;
  padding:.85em 1.6em; border-radius:100px; cursor:pointer; border:1px solid transparent;
  transition:transform .35s var(--ease), background .35s, color .35s, border-color .35s, box-shadow .35s;
  will-change:transform;
}
.btn--solid{ background:var(--accent); color:#fff; box-shadow:0 10px 30px -12px var(--accent); }
.btn--solid:hover{ background:var(--accent-2); transform:translateY(-2px); }
.btn--ghost{ border-color:var(--line); color:var(--cream); }
.btn--ghost:hover{ border-color:var(--gold); color:var(--gold); transform:translateY(-2px); }
.btn--pill{ background:var(--gold); color:#20160c; font-size:.8rem; padding:.6em 1.3em; }
.btn--pill:hover{ background:var(--gold-soft); transform:translateY(-2px); }

/* ---------- Canvas 3D ---------- */
.scene-canvas{ position:fixed; inset:0; width:100%; height:100vh; z-index:1; display:block; }
.scene-fallback{
  position:fixed; inset:0; z-index:1; display:none;
  background:
    radial-gradient(60% 55% at 50% 42%, rgba(231,177,90,.28), transparent 70%),
    radial-gradient(80% 80% at 50% 60%, #241d18, var(--bg) 75%);
}
body.no-webgl .scene-canvas{ display:none; }
body.no-webgl .scene-fallback{ display:block; background-size:cover; background-position:center;
  /* si assets/crepe-hero.jpg existe (Higgsfield), il s'affiche ; sinon le dégradé + emoji restent */
  background-image:url("../assets/crepe-hero.jpg"),
    radial-gradient(60% 55% at 50% 42%, rgba(231,177,90,.28), transparent 70%),
    radial-gradient(80% 80% at 50% 60%, #241d18, var(--bg) 75%); }
body.no-webgl .scene-fallback::after{
  content:"🥞"; position:absolute; inset:0; display:flex; align-items:center; justify-content:center;
  font-size:min(30vw,260px); filter:drop-shadow(0 30px 50px rgba(0,0,0,.6)); opacity:.9;
}

/* ---------- Hero ---------- */
.hero{ position:relative; z-index:10; height:100vh; display:flex; align-items:center; padding:0 var(--pad); pointer-events:none; }
.hero::before{ content:""; position:absolute; inset:0; pointer-events:none; z-index:1;
  background:linear-gradient(100deg, rgba(20,17,15,.82), rgba(20,17,15,.28) 46%, transparent 64%); }
.hero__inner{ max-width:620px; pointer-events:auto; position:relative; z-index:2; }
.hero__eyebrow{ font-size:.8rem; letter-spacing:.32em; text-transform:uppercase; color:var(--gold); margin-bottom:1.4rem; }
.hero__title{ font-family:var(--serif); font-weight:700; font-size:clamp(2.8rem,8vw,6.2rem); line-height:.98; letter-spacing:-.01em; }
.hero__title span{ display:block; }
.hero__title-em{ font-style:italic; color:var(--gold); }
.hero__sub{ margin:1.6rem 0 2.2rem; font-size:1.05rem; color:var(--muted); max-width:34ch; }
.hero__actions{ display:flex; gap:1rem; flex-wrap:wrap; }
.hero__rating{ margin-top:2rem; font-size:.9rem; color:var(--muted); display:flex; align-items:center; gap:.6rem; }
.hero__rating strong{ color:var(--cream); }
.stars{ color:var(--gold); letter-spacing:.1em; }
.stars__half{ opacity:.45; }
.hero__scroll{
  position:absolute; bottom:2rem; left:50%; transform:translateX(-50%);
  font-size:.7rem; letter-spacing:.3em; text-transform:uppercase; color:var(--muted);
  display:flex; flex-direction:column; align-items:center; gap:.6rem;
}
.hero__scroll span{ width:1px; height:38px; background:linear-gradient(var(--gold),transparent); animation:scrollLine 2s ease-in-out infinite; }
@keyframes scrollLine{ 0%,100%{ transform:scaleY(.4); opacity:.4; } 50%{ transform:scaleY(1); opacity:1; } }

/* Sections opaques par-dessus le canvas */
.trust, .section, .cta, .footer{ position:relative; z-index:10; background:var(--bg); }

/* ---------- Trust ---------- */
.trust{
  display:grid; grid-template-columns:repeat(4,1fr); gap:1.5rem;
  padding:3.5rem var(--pad); border-top:1px solid var(--line); border-bottom:1px solid var(--line);
  background:linear-gradient(var(--bg-2),var(--bg));
}
.trust__item{ text-align:center; }
.trust__item b{ display:block; font-family:var(--serif); font-size:clamp(2rem,5vw,3rem); color:var(--gold); line-height:1; }
.trust__item span{ font-size:.78rem; letter-spacing:.06em; color:var(--muted); text-transform:uppercase; }

/* ---------- Sections génériques ---------- */
.section{ padding:clamp(4rem,10vw,9rem) var(--pad); }
.section__head{ max-width:900px; margin:0 auto clamp(2.5rem,6vw,5rem); text-align:center; }
.section__kicker{ font-size:.78rem; letter-spacing:.3em; text-transform:uppercase; color:var(--gold); margin-bottom:1rem; }
.section__title{ font-family:var(--serif); font-weight:700; font-size:clamp(2rem,5.5vw,4rem); line-height:1.02; }

/* ---------- Cards ---------- */
.cards{ display:grid; grid-template-columns:repeat(3,1fr); gap:1.6rem; max-width:1100px; margin:0 auto; }
.card{
  background:var(--bg-2); border:1px solid var(--line); border-radius:var(--radius);
  padding:2rem 1.6rem; transition:transform .5s var(--ease), border-color .5s, background .5s;
  transform-style:preserve-3d; will-change:transform;
}
.card:hover{ border-color:rgba(231,177,90,.5); background:var(--bg-3); }
.card__media{ aspect-ratio:4/3; margin-bottom:1.1rem; border-radius:12px; overflow:hidden;
  display:grid; place-items:center; background:linear-gradient(150deg,var(--bg-3),#100c09);
  background-size:cover; background-position:center; transition:transform .6s var(--ease); }
.card:hover .card__media{ transform:scale(1.03); }
.card__emoji{ font-size:2.8rem; filter:drop-shadow(0 8px 14px rgba(0,0,0,.5)); }
.card.has-photo .card__emoji{ display:none; }
.card h3{ font-family:var(--serif); font-size:1.4rem; font-weight:600; margin-bottom:.5rem; }
.card p{ font-size:.9rem; color:var(--muted); }
.card__price{ display:inline-block; margin-top:1.1rem; font-weight:700; color:var(--gold); font-size:.9rem; }

/* ---------- Menu « à composer » (d'après les planches) ---------- */
.menu__intro{ color:var(--muted); margin-top:1rem; }
.menu__tabs{ display:flex; justify-content:center; gap:.6rem; margin-bottom:clamp(2rem,4vw,3rem); }
.menu-tab{
  font-family:var(--sans); font-weight:700; font-size:.95rem; letter-spacing:.02em;
  padding:.75em 1.7em; border-radius:100px; cursor:pointer;
  background:var(--bg-2); color:var(--muted); border:1px solid var(--line);
  transition:background .35s, color .35s, border-color .35s, transform .35s var(--ease);
}
.menu-tab:hover{ transform:translateY(-2px); color:var(--cream); }
.menu-tab.is-active{ background:var(--gold); border-color:var(--gold); color:#20160c; }
.menu-panel{ max-width:1050px; margin:0 auto; }
.menu-panel[hidden]{ display:none; }
.compose{ display:grid; grid-template-columns:repeat(2,1fr); gap:1.4rem; }
.compose__step{
  background:var(--bg-2); border:1px solid var(--line); border-radius:var(--radius);
  padding:1.6rem 1.5rem;
}
.compose__step h3{
  font-family:var(--serif); font-size:1.3rem; font-weight:600; margin-bottom:1rem;
  display:flex; align-items:center; gap:.7rem;
}
.compose__step h3 i{
  font-style:normal; font-family:var(--sans); font-size:.75rem; font-weight:800;
  width:1.9em; height:1.9em; border-radius:50%; display:grid; place-items:center;
  background:var(--gold); color:#20160c;
}
.chips{ display:flex; flex-wrap:wrap; gap:.5rem; }
.chip{
  font-size:.85rem; padding:.45em .95em; border-radius:100px;
  background:rgba(251,247,240,.05); border:1px solid var(--line); color:var(--cream);
  transition:border-color .3s, background .3s, transform .3s var(--ease); cursor:default;
}
.chip:hover{ border-color:var(--gold); background:rgba(231,177,90,.1); transform:translateY(-1px); }
/* accents par univers : framboise (planche rose) / or (planche salée) */
.menu-panel--sucre .compose__step h3 i{ background:var(--accent); color:#fff; }
.menu-panel--sucre .chip:hover{ border-color:var(--accent); background:rgba(232,70,91,.12); }
.menu__note{ text-align:center; color:var(--muted); font-size:.88rem; margin-top:2.2rem; }

/* ---------- Carte en images ---------- */
.menu-photos__grid{ display:grid; grid-template-columns:repeat(auto-fit,minmax(260px,1fr)); gap:1.4rem; max-width:1150px; margin:0 auto; }
.menu-photos__item{ display:block; border-radius:var(--radius); overflow:hidden; border:1px solid var(--line);
  background:var(--bg-2); transition:transform .5s var(--ease), border-color .5s; }
.menu-photos__item:hover{ transform:translateY(-4px); border-color:rgba(231,177,90,.5); }
.menu-photos__item img{ width:100%; height:100%; object-fit:cover; display:block; transition:transform .6s var(--ease); }
.menu-photos__item:hover img{ transform:scale(1.04); }

/* ---------- Reviews ---------- */
.reviews__grid{ display:grid; grid-template-columns:repeat(3,1fr); gap:1.4rem; max-width:1150px; margin:0 auto; }
.review{ background:var(--bg-2); border:1px solid var(--line); border-radius:var(--radius); padding:2rem; transition:transform .5s var(--ease), border-color .5s; }
.review:hover{ border-color:rgba(231,177,90,.4); }
.review__stars{ color:var(--gold); letter-spacing:.15em; margin-bottom:1rem; }
.review p{ font-family:var(--serif); font-size:1.25rem; line-height:1.4; }
.review cite{ display:block; margin-top:1.2rem; font-style:normal; font-size:.85rem; color:var(--muted); }

/* ---------- CTA ---------- */
.cta{ padding:clamp(4rem,9vw,7rem) var(--pad); text-align:center;
  background:linear-gradient(135deg,var(--choco),#1a0f09); }
.cta__inner h2{ font-family:var(--serif); font-size:clamp(2.2rem,6vw,4rem); }
.cta__inner p{ color:var(--muted); margin:1rem 0 2rem; }
.cta__actions{ display:flex; gap:1rem; justify-content:center; flex-wrap:wrap; }

/* ---------- Contact ---------- */
.contact{ display:grid; grid-template-columns:1.1fr 1fr; gap:clamp(2rem,6vw,5rem); align-items:start; max-width:1150px; margin:0 auto; }
.contact .section__title{ text-align:left; margin-bottom:1.8rem; }
.contact__list{ list-style:none; margin-bottom:2rem; }
.contact__list li{ padding:1rem 0; border-bottom:1px solid var(--line); font-size:.98rem; color:var(--muted); }
.contact__list li b{ display:block; color:var(--gold); font-size:.72rem; letter-spacing:.18em; text-transform:uppercase; margin-bottom:.3rem; }
.contact__list li a:hover{ color:var(--gold); }
.contact__form{ display:grid; gap:1rem; }
.field{ position:relative; }
.field input, .field textarea{
  width:100%; background:var(--bg-2); border:1px solid var(--line); border-radius:12px;
  padding:1.1rem 1rem .5rem; color:var(--cream); font-family:var(--sans); font-size:.95rem; resize:vertical;
  transition:border-color .3s;
}
.field textarea{ padding-top:1.3rem; }
.field label{ position:absolute; left:1rem; top:.95rem; color:var(--muted); font-size:.95rem; pointer-events:none; transition:.25s var(--ease); }
.field input:focus, .field textarea:focus{ outline:none; border-color:var(--gold); }
.field input:focus + label, .field textarea:focus + label,
.field input:not(:placeholder-shown) + label, .field textarea:not(:placeholder-shown) + label{
  top:.35rem; font-size:.68rem; letter-spacing:.08em; color:var(--gold);
}
.contact__note{ font-size:.85rem; color:var(--gold); min-height:1.2em; }
.contact__map{
  aspect-ratio:1/1.1; border-radius:24px; border:1px solid var(--line);
  display:flex; flex-direction:column; align-items:center; justify-content:center; gap:1rem;
  background:linear-gradient(160deg,var(--bg-3),var(--bg));
  color:var(--muted); font-size:.85rem; letter-spacing:.1em; text-transform:uppercase;
  transition:border-color .4s, transform .4s var(--ease);
}
.contact__map:hover{ border-color:var(--gold); transform:translateY(-3px); }
.contact__pin{ font-size:3rem; animation:floaty 3s ease-in-out infinite; }

/* ---------- Footer ---------- */
.footer{ text-align:center; padding:4rem var(--pad) 3rem; border-top:1px solid var(--line); }
.footer__brand{ font-family:var(--serif); font-size:1.8rem; font-weight:700; margin-bottom:1.3rem; }
.footer__brand span{ color:var(--gold); }
.footer__nav{ display:flex; gap:1.8rem; justify-content:center; flex-wrap:wrap; margin-bottom:1.5rem; }
.footer__nav a{ font-size:.82rem; letter-spacing:.08em; text-transform:uppercase; color:var(--muted); }
.footer__nav a:hover{ color:var(--gold); }
.footer__meta{ font-size:.85rem; color:var(--muted); margin-bottom:.6rem; }
.footer__copy{ font-size:.78rem; color:rgba(251,247,240,.4); }

/* ---------- Mobile CTA flottant ---------- */
.mobile-cta{
  position:fixed; bottom:1rem; left:1rem; right:1rem; z-index:150; display:none;
  text-align:center; padding:1rem; border-radius:100px; background:var(--accent); color:#fff;
  font-weight:700; letter-spacing:.04em; box-shadow:0 14px 30px -10px var(--accent);
}

/* ---------- Reveal ---------- */
[data-reveal]{ opacity:0; transform:translateY(38px); transition:opacity .9s var(--ease), transform .9s var(--ease); }
[data-reveal].in{ opacity:1; transform:none; }
[data-hero="up"]{ opacity:0; transform:translateY(30px); }

/* ---------- Responsive ---------- */
@media (max-width:900px){
  .nav__links{ position:fixed; inset:0; background:rgba(22,19,17,.97); backdrop-filter:blur(18px);
    flex-direction:column; align-items:center; justify-content:center; gap:2rem; margin:0;
    transform:translateY(-100%); transition:transform .5s var(--ease); }
  .nav.open .nav__links{ transform:none; }
  .nav__links a{ font-size:1.4rem; }
  .nav__cta{ display:none; }
  .nav__burger{ display:flex; z-index:210; }
  .trust{ grid-template-columns:repeat(2,1fr); gap:2.2rem 1rem; }
  .cards{ grid-template-columns:repeat(2,1fr); }
  .menu__grid{ grid-template-columns:1fr; }
  .reviews__grid{ grid-template-columns:1fr; }
  .contact{ grid-template-columns:1fr; }
  .contact__map{ aspect-ratio:16/10; }
  .mobile-cta{ display:block; }
  .footer{ padding-bottom:6rem; }
  .hero::before{ background:linear-gradient(180deg, rgba(20,17,15,.55) 0%, rgba(20,17,15,.12) 28%, rgba(20,17,15,.6) 72%, rgba(20,17,15,.9) 100%); }
}
@media (max-width:520px){
  .cards{ grid-template-columns:1fr; }
  .hero__actions{ width:100%; }
}

/* ---------- Reduced motion ---------- */
@media (prefers-reduced-motion:reduce){
  *{ animation:none !important; scroll-behavior:auto !important; }
  [data-reveal]{ opacity:1; transform:none; transition:none; }
  .cursor{ display:none; }
}
